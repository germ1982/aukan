// Solo para sqlsrv
function IniciarTransaccion() {
  sqlsrv_query("BEGIN TRANSACTION",$this->CONEXION);
}

function CommitTransaccion() {
  sqlsrv_query("COMMIT",$this->CONEXION);
}

function RollbackTransaccion() {
  sqlsrv_query("ROLLBACK",$this->CONEXION);
}

function sqlsrv_insert_id() {
  $id = "";

  $rs = sqlsrv_query($this->CONEXION, "SELECT @@identity AS id");
  if ($row = sqlsrv_fetch_array($rs)) {
   $id = trim($row[0]);
  }
  //sqlsrv_free_result($rs);
  sqlsrv_free_stmt($rs);
  return $id;
}

